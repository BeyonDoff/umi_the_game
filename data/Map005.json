"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac而门口的身影，就是合同中的甲方————"]},{"code":401,"indent":0,"parameters":["\\dac海猫"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac虽然和我曾痴迷的主播很像，但她似乎又并不是那个人、"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac她承认和那个主播有间接的关系，但称对方为“她”、"]},{"code":401,"indent":0,"parameters":["\\dac同时称呼自己为“阿海”。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac意料之外的是，她似乎也对我这个“她”的粉丝很感兴趣。"]},{"code":401,"indent":0,"parameters":["\\dac总之、在酒馆里发生了一些比较成人的事情。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST LEFT FALSE"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我：所以我们什么时候签过这样的契约？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：刚刚。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["我：……刚刚？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：因为你回到了这里这件事，"]},{"code":401,"indent":0,"parameters":["它本身就说明我们的契约已经成立了。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我无言以对，"]},{"code":401,"indent":0,"parameters":["\\dac因为我确实在审核官面前默认了这份契约的存在。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac看到她露出的笑容时，"]},{"code":401,"indent":0,"parameters":["\\dac我恍惚中想起了她在分别时说的话————"]},{"code":231,"indent":0,"parameters":[3,"CG039",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[3,0,0,0,0,0,100,100,255,0,30,true]},{"code":230,"indent":0,"parameters":[30]},{"code":232,"indent":0,"parameters":[3,0,0,0,0,0,100,100,0,0,30,true]},{"code":235,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：为什么你会觉得第一次见面就和你做那种事情的我、"]},{"code":401,"indent":0,"parameters":["是好女孩呢？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac不知道为什么，现在的海猫仿佛能看穿我的一切想法"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac无论目的是什么，这份契约确实完全地生效了。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac事实确凿，我能做的也只有重新注视起她的眼睛、"]},{"code":401,"indent":0,"parameters":["\\dac或许那对红色的眸子会给我想要的答案。"]},{"code":231,"indent":0,"parameters":[2,"CG020",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":0,"parameters":[1]},{"code":230,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac看到我终于投来对视的目光，海猫似乎很欣慰地点了点头。"]},{"code":401,"indent":0,"parameters":["\\dac随后她向我发出了欢迎————"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：欢迎来到，地狱十八号酒馆。"]},{"code":230,"indent":0,"parameters":[60]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[2]},{"code":201,"indent":0,"parameters":[0,7,9,9,0,0]},{"code":222,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":8,"y":13}
