{"id":6,"list":[{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我打开了本子，"]},{"code":401,"indent":0,"parameters":["\\dac今天能写些什么呢？"]},{"code":111,"indent":0,"parameters":[1,6,0,0,0]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac今天是第一天写日记，"]},{"code":401,"indent":1,"parameters":["\\dac所以、总之、先随便写点什么吧。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac即使在来到地狱前我也几乎没写过日记，"]},{"code":401,"indent":1,"parameters":["\\dac突然要开始确实还有些困难。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac不过、反正也没其他人能看到，"]},{"code":401,"indent":1,"parameters":["\\dac就算是写一堆流水账也无所谓吧。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac我的笔尖在纸上顿了顿，"]},{"code":401,"indent":1,"parameters":["\\dac随后便放任文字像小河淌水一样顺流而下。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac我的第一篇日记。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac今天是我在酒吧的第\\v[5]天，"]},{"code":401,"indent":1,"parameters":["\\dac我觉得我还是很喜欢海猫小姐，"]},{"code":401,"indent":1,"parameters":["\\dac但我也必须承认她不是我熟悉的那个人。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac回到我的生活的话——"]},{"code":401,"indent":1,"parameters":["\\dac没有手机、没有游戏、没有漫画，"]},{"code":401,"indent":1,"parameters":["\\dac我已经很久没有过这种无所适从的感觉了。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac这种感觉很难描述，"]},{"code":401,"indent":1,"parameters":["\\dac可能就像第一次学会玩电脑关机后看着它黑下去的屏幕。"]},{"code":401,"indent":1,"parameters":["\\dac在短暂的快乐结束后，反光中出现的那张自己的脸。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac明明是自己，却又不那么像是自己。"]},{"code":401,"indent":1,"parameters":["\\dac似乎他想对我说什么，但我听不到。"]},{"code":401,"indent":1,"parameters":["\\dac但这种时候除了试着去听些什么，也做不了其他事了。"]},{"code":101,"indent":1,"parameters":["",0,0,1]},{"code":401,"indent":1,"parameters":["\\dac我应该有很多想得到的答案，"]},{"code":401,"indent":1,"parameters":["\\dac虽然我也不知道我要问的问题是什么。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac写完了一堆谜语发言后，"]},{"code":401,"indent":1,"parameters":["\\dac我合上了日记本。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac欲望值减少了"]},{"code":122,"indent":1,"parameters":[1,1,2,0,1]},{"code":111,"indent":1,"parameters":[1,1,0,0,4]},{"code":122,"indent":2,"parameters":[1,1,0,0,0]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,6,0,1,1]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac抬起头时，"]},{"code":401,"indent":1,"parameters":["\\dac自己已经写了一些不知所谓的无聊内容、"]},{"code":401,"indent":1,"parameters":["\\dac那么今天就写到这了。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac欲望值减少了"]},{"code":122,"indent":1,"parameters":[1,1,2,0,1]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"name":"日记内容","switchId":1,"trigger":0},
{"id":7,"list":[{"code":111,"indent":0,"parameters":[0,9,0]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac在梦中闻到了赛博玫瑰的香味，"]},{"code":401,"indent":1,"parameters":["\\dac尽管我其实并不知道它是什么味道。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac但我的潜意识告诉我，"]},{"code":401,"indent":1,"parameters":["\\dac那就是这种令我沉醉的味道。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac帷幔后有个模糊的人影、"]},{"code":401,"indent":1,"parameters":["\\dac我觉得我应该去见她。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac但轻薄通透的帷幔却如同厚厚的墙壁，"]},{"code":401,"indent":1,"parameters":["\\dac始终难以穿过。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac我觉得总有一天我会见到那个人，"]},{"code":401,"indent":1,"parameters":["\\dac只是时机未到。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac欲望值增加了"]},{"code":122,"indent":1,"parameters":[1,1,1,0,1]},{"code":115,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac很软的床、"]},{"code":401,"indent":1,"parameters":["\\dac我的意识逐渐被什么包裹、"]},{"code":401,"indent":1,"parameters":["\\dac随后沉向深处。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac欲望值减少了"]},{"code":122,"indent":1,"parameters":[1,1,2,0,1]},{"code":111,"indent":1,"parameters":[1,1,0,0,4]},{"code":122,"indent":2,"parameters":[1,1,0,0,0]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"name":"做梦内容","switchId":1,"trigger":0},
