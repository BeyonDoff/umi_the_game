rs":[]},{"code":115,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"否"]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我搞不太清楚自己在审核官面前递上材料时是什么心情。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac是释然？无奈？遗憾？开心？放松？紧张？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac又或是单纯的迷茫？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac但无论如何，只要这轮审核通过，"]},{"code":401,"indent":0,"parameters":["\\dac这件事就不再有考虑的意义了。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac因为在这之后，连“我”的意义也将不复存在。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac灵魂从地狱重返人间，死后再回到这里，"]},{"code":401,"indent":0,"parameters":["\\dac这种哲学问题可以留给下辈子的我用一生去想。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["审核官：嗯…感觉材料没什么问题。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac审核官的话把我从思考中拯救了出来。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac这里应该用拯救吗？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac如释重负的我像考完高考的毕业生一样，"]},{"code":401,"indent":0,"parameters":["\\dac已经开始让思绪飘向未知的某处。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["审核官：但是，有个坏消息要告诉你。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我仿佛听到了什么东西碎掉的声音。"]},{"code":401,"indent":0,"parameters":["\\dac但我觉得这应该只是个错觉。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["审核官：你还