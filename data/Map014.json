ent":0,"parameters":["\\dac我当然也有自己的猜测，"]},{"code":401,"indent":0,"parameters":["\\dac但这对于目前的情况…"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["不用一直想下去哦？"]},{"code":401,"indent":0,"parameters":["我只是想告诉你，"]},{"code":401,"indent":0,"parameters":["你有自己的想法就够了。"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["比起别人的答案，"]},{"code":401,"indent":0,"parameters":["其实还是自己心里的答案更好接受吧？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac自己心里的答案…吗？"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["海猫继续用叉子去对手里的布丁进行凌迟处死，"]},{"code":401,"indent":0,"parameters":["随后露出幸福的表情来。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac虽然不知道用小叉子吃布丁究竟是怎样的爱好，"]},{"code":401,"indent":0,"parameters":["\\dac但既然对方能正常地吃下去，"]},{"code":401,"indent":0,"parameters":["\\dac显然也就没有去质疑的必要。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["换个角度来看，用她的笑容来下饭的话，"]},{"code":401,"indent":0,"parameters":["现在的我或许吃下一根巧克力威化也不在话下吧。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["于是我剥开包装，将久违的甜食送入口中。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac如果我对从前的我说，"]},{"code":401,"indent":0,"parameters":["\\dac我会因为一根威化饼干就感觉吃饱，"]},{"code":401,"indent":0,"parameters":["\\dac他会不会觉得是在开玩笑呢？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac不过，显然现在能和海猫一起、"]},{"code":401,"indent":0,"parameters":["\\dac坐在桌前一起吃喝闲聊的情景，"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac才是对他来说，最难以置信的玩笑吧。"]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[1]},{"code":235,"indent":0,"parameters":[