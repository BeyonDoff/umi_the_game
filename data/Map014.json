ode":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["是我藏起来准备偷吃的。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac光明正大说出来了还算偷吃吗？"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",6,0,2]},{"code":401,"indent":0,"parameters":["唔…好像确实偷吃不太准确？"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["总之，因为“她”总觉得吃东西很容易长胖，"]},{"code":401,"indent":0,"parameters":["所以这座酒馆里的人完全不会积攒食欲。"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",6,0,2]},{"code":401,"indent":0,"parameters":["我也是等了好久"]},{"code":401,"indent":0,"parameters":["才感觉自己可以吃得下这只布丁的…"]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["布丁随着海猫的手轻轻摇晃，"]},{"code":401,"indent":0,"parameters":["看上去非常诱人。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac但我确实并没有很想吃下它的想法。"]},{"code":401,"indent":0,"parameters":["\\dac到底是怎么做到的？"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["所以没关系哦，"]},{"code":401,"indent":0,"parameters":["海雅人想吃的话就可以拿去吃。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["桌上的各种点心看着都很诱人，"]},{"code":401,"indent":0,"parameters":["按理说也会很令人有食欲才对。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST LEFT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",0,0,2]},{"code":401,"indent":0,"parameters":["诶？等等，那之前海猫小姐在储藏室…"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["没错，我就是在找它们啊。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac背着我找，但是找到后又大大方方摆到我眼前吗？"]},{"code":401,"indent":0,"parameters":["\\dac这怎么想都好奇怪啊…"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["毕竟真看到它们的时候，"]},{"code":401,"indent":0,"parameters":["我才发觉自己根本吃不掉它们。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["这话倒说得在理，"]},{"code":401,"indent":0,"parameters":["我看向桌上的甜点、糕点、巧克力、饼干等食物。"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["如果是生前我觉得这些只是我最多一周的小零食，"]},{"code":401,"indent":0,"parameters":["但现在的我，"]},{"code":401,"indent":0,"parameters":["却可能连打开一根能量棒都需要做下心理准备。"]},{"code":231,"indent":0,"parameters":[2,"CG065",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,0,0,0,0,100,100,255,0,60,true]},{"code":235,"indent":0,"parameters":[1]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",6,0,2]},{"code":401,"indent":0,"parameters":["所以，海雅人…"]},{"code":401,"indent":0,"parameters":["要来点吗？"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["海猫小姐吃下了一口布丁，"]},{"code":401,"indent":0,"parameters":["然后恶作剧般地夹出了主播一样魅惑的营业声线。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac真了不起啊，能吃一整个布丁。"]},{"code":401,"indent":0,"parameters":["\\dac但我作为死宅，可不会在这种地方认输！"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["我的手努力地在零食中翻找，"]},{"code":401,"indent":0,"parameters":["然后紧紧握住了一条巧克力威化饼干。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac等等，刚刚的死宅似乎是个很棒的双关语啊。"]},{"code":401,"indent":0,"parameters":["\\dac要不要在吃东西之前先做下笔记呢…"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameter