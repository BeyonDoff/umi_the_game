ters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海雅人：呃…需要我做什么吗？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：能给我调杯酒吗？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac调酒的话，虽然算不上多专业，"]},{"code":401,"indent":0,"parameters":["\\dac但姑且也操作过几次了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海雅人：嗯…只要我会调就行？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：我们来做个假设吧。"]},{"code":401,"indent":0,"parameters":["假设现在我是刚走进酒馆的，"]},{"code":401,"indent":0,"parameters":["刚来到地狱的海猫小姐。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac说实话这个假设有够奇怪的，"]},{"code":401,"indent":0,"parameters":["\\dac海猫小姐不会熬夜看了什么哲学书籍吧？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：店员先生，能给我调一杯酒吗？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海雅人：诶？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["无论怎么想都是酒馆的海猫小姐的女生，"]},{"code":401,"indent":0,"parameters":["突然用很营业的声线扮演起了我喜欢的主播。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["明明是非常反常非常奇怪的事情…"]},{"code":401,"indent":0,"parameters":["可是我的大脑确实有那么一瞬间相信了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：店员先生以前认识我吗？"]},{"code":401,"indent":0,"parameters":["不会还看过我直播吧？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["说实话我已经开始宕机了，"]},{"code":401,"indent":0,"parameters":["但尽职的大脑用下意识的反应让我点了点头。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：那真是太幸运了，"]},{"code":401,"indent":0,"parameters":["店员先生也是海雅人的话，"]},{"code":401,"indent":0,"parameters":["一定能给我推荐最合适的酒吧？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["如果不看长相"]},{"code":401,"indent":0,"parameters":["——虽然我也不知道主播海猫umi真正的长相，"]},{"code":401,"indent":0,"parameters":["现在在我面前的简直就像是海猫本人一样。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海雅人：抱歉…我、我不是店员…"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我感觉自己开始退缩了，"]},{"code":401,"indent":0,"parameters":["不好的往事似乎又要涌上心头。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：还是说，"]},{"code":401,"indent":0,"parameters":["其实店员先生其实以前是很讨厌我的人？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["不不不，我毫不犹豫地摇起头，"]},{"code":401,"indent":0,"parameters":["无论如何这种误会是绝对不能出现的。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["沉浸在扮演中的“海猫”似乎露出了奸计得逞的笑容，"]},{"code":401,"indent":0,"parameters":["真是被摆了一道。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：我给店员先生讲个故事吧。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：从楼上一跃而下死去的少女来到了地狱，"]},{"code":401,"indent":0,"parameters":["被酒馆的店主捡到，于是成为了店员。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我无法组织起回答，"]},{"code":401,"indent":0,"parameters":["\\dac只能继续静静听着。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac从开头来看，这似乎是主播海猫的角色设定，"]},{"code":401,"indent":0,"parameters":["\\dac当然也可能是店员少女过去的回忆。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：她发现所有客人都对自己非常友善，"]},{"code":401,"indent":0,"parameters":["甚至一看到自己就会痛哭出声。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：于是她向店长提问，"]},{"code":401,"indent":0,"parameters":["店长告诉她，全因酒馆里有神奇的法术。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：这是地狱负责送走亡魂的酒馆，"]},{"code":401,"indent":0,"parameters":["而离开地狱回到轮回的条件，"]},{"code":401,"indent":0,"parameters":["就是不增加额外的因果。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：于是每个来酒馆的人，"]},{"code":401,"indent":0,"parameters":["眼里的女孩都只会是到自己最想念的女性的样子。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：在客人的眼里，"]},{"code":401,"indent":0,"parameters":["店员永远是自己最想念的女性年轻的样子，"]},{"code":401,"indent":0,"parameters":["也做着符合自己认知中对方会做的事情…"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：客人不会在酒吧遇见新的人、"]},{"code":401,"indent":0,"parameters":["也只会继续加深对所念之人的思念，"]},{"code":401,"indent":0,"parameters":["这样也就不会产生新的因果。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["等等…我几乎要出声打断了，"]},{"code":401,"indent":0,"parameters":["但还是在最后一刻紧紧抿住了嘴。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：店员先生，现在在你的眼中，"]},{"code":401,"indent":0,"parameters":["那位少女长得是什么样子？"]},{"code":401,"indent":0,"parameters":["她平时又会做些什么呢？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海雅人：我…我不知道，"]},{"code":401,"indent":0,"parameters":["我看不清你现在的脸，"]},{"code":401,"indent":0,"parameters":["但我总觉得你还是海猫。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac这么想的话，"]},{"code":401,"indent":0,"parameters":["\\dac最想念的女性竟然是虚拟主播的形象，"]},{"code":401,"indent":0,"parameters":["\\dac我是不是也已经是极致的管人痴了？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["“海猫”摊了摊手，"]},{"code":401,"indent":0,"parameters":["似乎是露出了苦笑。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：因为你现在正处于一种很奇怪的叠加态里，"]},{"code":401,"indent":0,"parameters":["你接下来的决定会决定你是否会重新回到轮回，"]},{"code":401,"indent":0,"parameters":["又或是留下来，成为店员。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：毕竟认知干扰法术的主要目标是客人，"]},{"code":401,"indent":0,"parameters":["而不是会一直留在地狱里的店员。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：如果真的变成店员先生的话，"]},{"code":401,"indent":0,"parameters":["可能你眼中的我真的会变成其他的人了吧？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我咽了咽口水，"]},{"code":401,"indent":0,"parameters":["整理着庞杂涌来的信息。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac店员少女，也就是阿海小姐。"]},{"code":401,"indent":0,"parameters":["\\dac她在我眼中是主播海猫umi的样子。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac但很可能，"]},{"code":401,"indent":0,"parameters":["\\dac这只是认知干扰法阵造成的影响。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac她的长相、甚至她在这两周中做过的事，"]},{"code":401,"indent":0,"parameters":["\\dac可能都是我脑海中海猫的样子，"]},{"code":401,"indent":0,"parameters":["\\dac而不是她真正的样子、她真正会做的事。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我无法判断这种离奇的说法是真是假，"]},{"code":401,"indent":0,"parameters":["\\dac但我也的确很难想出一个对现状更合理的解释。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：没事的，"]},{"code":401,"indent":0,"parameters":["海雅人只需要相信自己的判断就好。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：我只是想给海雅人一个更方便的思路。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：比如说，"]},{"code":401,"indent":0,"parameters":["其实你也可以不考虑给海猫小姐该上什么酒、"]},{"code":401,"indent":0,"parameters":["而是换一种角度去思考、"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫？：决定这杯酒选择的，到底该是谁呢？"]},{"code":401,"indent":0,"parameters":["是海雅人吗？或者是阿海小姐？"]},{"code":401,"indent":0,"parameters":["又或是海猫自己？"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac说实话，"]},{"code":401,"indent":0,"parameters":["\\dac在猛然接受了巨大信息量后又听到这些，"]},{"code":401,"indent":0,"parameters":["\\dac我已经有些被绕晕了。"]},{"code":101,"in