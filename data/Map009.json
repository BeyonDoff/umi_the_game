,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac这显得有些慵懒疲惫的声线对我却重如磐石。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac“那第一次见面时，我们做那件事时换的衣服。”"]},{"code":401,"indent":0,"parameters":["\\dac但这种答案多少有些难以启齿了。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac一旦回想起那时的场景，"]},{"code":401,"indent":0,"parameters":["\\dac两具交缠的肉体、我的那些意乱情迷的话语，"]},{"code":401,"indent":0,"parameters":["\\dac一股难以明说的感觉就会从心头生起。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",1,0,2]},{"code":401,"indent":0,"parameters":["因为前两天弄脏了，所以洗完昨天刚晾干…"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我当然记得啊、"]},{"code":401,"indent":0,"parameters":["\\dac不要再故意提示我了、"]},{"code":401,"indent":0,"parameters":["\\dac我的喉咙滚动，但依然没发出应有的声音。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac这已经不是普通的诱惑了、"]},{"code":401,"indent":0,"parameters":["\\dac必须出重拳！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac但其实怎么想她都只是在责怪我上次弄脏了衣服吧、"]},{"code":401,"indent":0,"parameters":["\\dac我的理智在最后一刻把思绪拉了回来。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac你有这么高速运转的机器进入中国、"]},{"code":401,"indent":0,"parameters":["\\dac如来、他真的来了吗？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac那我问你、那我问你、"]},{"code":401,"indent":0,"parameters":["\\dac你不知道！你不在乎！你只关心你自己！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我一言不发的天人交战显然打消了海猫的兴致、"]},{"code":401,"indent":0,"parameters":["\\dac于是两声干咳终于打断了我的胡思乱想。"]},{"code":231,"indent":0,"parameters":[3,"CG025",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",1,0,2]},{"code":401,"indent":0,"parameters":["咳咳、所以海雅人过来是有什么事吗？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac（没什么事，我只是想靠近看看你）"]},{"code":401,"indent":0,"parameters":["\\dac（哇、这句话好恶心…）"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我努力地把注意力拽了回来，"]},{"code":401,"indent":0,"parameters":["\\dac寻找着合适的理由。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我：尾巴。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",0,0,2]},{"code":401,"indent":0,"parameters":["诶？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac在我眼前摇晃的猫尾巴，是我一把抓住的救命稻草。"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac这样不过大脑的回答，"]},{"code":401,"indent":0,"parameters":["\\dac却让之前仿佛一切尽在掌握的海猫感到了惊讶。"]},{"code":231,"indent":0,"parameters":[1,"CG027",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[1,0,0,0,0,0,100,100,255,0,60,true]},{"code":235,"indent":0,"parameters":[2]},{"code":235,"indent":0,"parameters":[3]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我：想摸摸尾巴！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac急中生智的我，选择进一步抓住我的救命稻草、"]},{"code":401,"indent":0,"parameters":["\\dac这次是物理上的。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac海猫的身子剧烈地颤抖了一下、"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：性骚扰…"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac性骚扰？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac当大脑迟缓地处理完听到的信息时，"]},{"code":401,"indent":0,"parameters":["\\dac我慌忙松开了手。"]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[2,"CG028",0,0,0,0,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,0,0,0,0,100,100,255,0,60,true]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac而在我刚松开手时，"]},{"code":401,"indent":0,"parameters":["\\dac那条尾巴便灵巧地逃开，最后缩回了海猫的裙下。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac等等，缩到了裙下？"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",1,0,2]},{"code":401,"indent":0,"parameters":["我是作为人类来到地狱的哦？"]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac大脑未响应。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",0,0,2]},{"code":401,"indent":0,"parameters":["猫耳朵或者猫尾巴，"]},{"code":401,"indent":0,"parameters":["虽然也能看做我身体的一部分、"]},{"code":401,"indent":0,"parameters":["但并不是“一定要露出来的”什么器官。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac大脑…突然从潜意识里发出了怒吼。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac可恶，我对海猫的爱和猫或者人都没什么关系啊！"]},{"code":401,"indent":0,"parameters":["\\dac连我一直以来的称呼可都是猫耳少女！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac不对、猫耳少女、猫耳少女…"]},{"code":401,"indent":0,"parameters":["\\dac所以这算猫娘还是…"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",1,0,2]},{"code":401,"indent":0,"parameters":["不是猫娘，是人类。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我：好方便的设定啊…(小声)"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac一句几乎没有经过任何思考的吐槽从嘴里蹦了出来、"]},{"code":401,"indent":0,"parameters":["\\dac当我急忙闭上嘴时已经来不及了。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac但海猫却一直保持着似乎很愉悦的表情，"]},{"code":401,"indent":0,"parameters":["\\dac是我刚才说了什么让她觉得有意思的话吗？"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_testa",1,0,2]},{"code":401,"indent":0,"parameters":["总之，如果哪天我投诉你，"]},{"code":401,"indent":0,"parameters":["地狱也会按照对人类作恶审判你哦~"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST LEFT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",1,0,2]},{"code":401,"indent":0,"parameters":["对、对不起！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac大脑过载了、"]},{"code":401,"indent":0,"parameters":["\\dac总之先跪下道歉吧，他临终前这么发出指示。"]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac在我一番痛彻心扉的道歉后，"]},{"code":401,"indent":0,"parameters":["\\dac海猫带着“真是看了一出好戏”的表情轻易地原谅了我。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac“下次别再随便弄脏女孩子的衣服哦。”"]},{"code":401,"indent":0,"parameters":["\\dac\"哦，还有、随便摸女孩子的尾巴也不行！\""]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac说完，海猫就离开了。"]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac话说，虽然有像猫耳一样的器官甚至名字有猫、"]},{"code":401,"indent":0,"parameters":["\\dac但不是猫而是纯粹的人类少女，"