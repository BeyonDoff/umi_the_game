:0,"parameters":["海猫的身影正在各个坐满“人”的桌间穿行，"]},{"code":401,"indent":0,"parameters":["一眼望去竟然很难找到有空着的座位。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac原来人声鼎沸、高朋满座这一类的形容词"]},{"code":401,"indent":0,"parameters":["\\dac是可以用在这间酒馆上的吗？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["看着眼前反常的景象，"]},{"code":401,"indent":0,"parameters":["我不仅有了些恍惚感。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac是不是打开方式不太对，"]},{"code":401,"indent":0,"parameters":["\\dac应该回楼上再下来一次？"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["我刚想转身试试重启场景操作时，"]},{"code":401,"indent":0,"parameters":["腰上的软肉便被狠狠捏了一把。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：今天阳间不知道发生什么事了，"]},{"code":401,"indent":0,"parameters":["总之下来了好多爱喝酒的中老年人…"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["海猫：总之、过！来！帮！忙！"]},{"code":231,"indent":0,"parameters":[2,"CG089",0,0,0,0,100,100,255,0]},{"code":235,"indent":0,"parameters":[1]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["当我回过神来的时候，"]},{"code":401,"indent":0,"parameters":["身体已经在酒馆里来回跑了好几圈了。"]},{"code":111,"indent":0,"parameters":[1,2,0,10,1]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["虽说平时也没少干活，"]},{"code":401,"indent":1,"parameters":["但在闲逛时候被抓壮丁多少还是有些猝不及防。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["幸好现在的我仅靠肌肉记忆"]},{"code":401,"indent":1,"parameters":["也已经能轻松解决大多数的工作了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["本来剩下要待在酒馆的日子也不多了，"]},{"code":401,"indent":1,"parameters":["还是能多分担些工作就多分担一些吧。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac努力值大幅增加了"]},{"code":122,"indent":1,"parameters":[2,2,1,0,2]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["在休息时被突然抓来当苦力"]},{"code":401,"indent":1,"parameters":["还是让我有些猝不及防"]},{"code":401,"indent":1,"parameters":["——虽然我平时也没少休息就是了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["无论如何，突然就开始这么高强度的工作，"]},{"code":401,"indent":1,"parameters":["真是有点太抬举我这个废物阿宅了。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac努力值增加了"]},{"code":122,"indent":1,"parameters":[2,2,1,0,1]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["虽然店里依然人头攒动，"]},{"code":401,"indent":0,"parameters":["但我们总算还是找到了能短暂休息一下的空隙。"]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[1]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["体力还行吗？"]},{"code":401,"indent":0,"parameters":["海猫在经过我时小声询问。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac说实话她自己应该是最累的吧，"]},{"code":401,"indent":0,"parameters":["\\dac现在竟然还要抽空关心我。"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac当然，真要我说自己不累的话，"]},{"code":401,"indent":0,"parameters":["\\dac显然也有些太违心了。"]},{"code":111,"indent":0,"parameters":[1,2,0,15,1]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["海雅人：别担心，问题不大。"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac这倒也不是在硬撑说大话，"]},{"code":401,"indent":1,"parameters":["\\dac主要还是平时没少帮忙干活，"]},{"code":401,"indent":1,"parameters":["\\dac对各种工作流程已经足够熟悉了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["海猫向我投来了一个意味深长的眼神，"]},{"code":401,"indent":1,"parameters":["小声嘟囔了几句，"]},{"code":401,"indent":1,"parameters":["但并没有阻止我继续工作。"]},{"code":111,"indent":1,"parameters":[0,8,0]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\dac不知为何，明明不会读唇语的我"]},{"code":401,"indent":2,"parameters":["\\dac却似乎隐约能从她的口型中读出意思——"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\dac竟然没有要回报吗，"]},{"code":401,"indent":2,"parameters":["\\dac真不像你啊…"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\dac原来在海猫小姐眼里我是这样的人吗…"]},{"code":401,"indent":2,"parameters":["\\dac不对，"]},{"code":401,"indent":2,"parameters":["\\dac如果是平时的我应该确实会趁机要点福利？"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["我连忙摇晃脑袋把思绪拉回正轨，"]},{"code":401,"indent":2,"parameters":["现在显然并不是思考这些有的没的的时候。"]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":231,"indent":1,"parameters":[1,"CG090",0,0,0,0,100,100,255,0]},{"code":222,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":[""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["于是我转身开始再次投入工作，"]},{"code":401,"indent":1,"parameters":["与其说是有什么目的，"]},{"code":401,"indent":1,"parameters":["不如说确实已经习惯了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["海猫似乎又若有所思地站了会，"]},{"code":401,"indent":1,"parameters":["很快也被逐渐增加的客人招呼声拉回了工作中。"]},{"code":231,"indent":1,"parameters":[2,"CG091",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[2,0,0,0,0,0,100,100,255,0,60,true]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":[""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["海猫：…谢谢你，海雅人。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["在一次擦身而过时，"]},{"code":401,"indent":1,"parameters":["我隐约听到了海猫如此小声说着。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["但来不及细想其中具体的含义，"]},{"code":401,"indent":1,"parameters":["现在果然还是处理酒馆里的事务最为优先。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["接待客人然后推荐酒水、"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["听取点单之后计算价格、"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["制作饮品接着装饰端盘、"]},{"code":101,"indent":1,"parameters":["",0,1,1]},{"code":401,"indent":1,"parameters":["\\dac搞什么啊，"]},{"code":401,"indent":1,"parameters":["\\dac原来这两周不到的时间我已经学了这么多东西吗？"]},{"code":221,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["直到最后的门口铃铛声响起，"]},{"code":401,"indent":1,"parameters":["标志着最后客人的离去，"]},{"code":401,"indent":1,"parameters":["我才终于停下了不断下意识游走的脚步。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["我终于有空细细去看海猫向我投来的眼神，"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["在酒馆并不晃眼的灯光下，"]},{"code":401,"indent":1,"parameters":["红色的眼瞳却似乎反射出了宝石般夺目的光芒。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["在逐渐放大的心跳声中，"]},{"code":401,"indent":1,"parameters":["我终于意识到自己正在和眼睛的主人直直地对视着。"]},{"code":231,"indent":1,"parameters":[1,"CG083",0,0,0,0,100,100,255,0]},{"code":235,"indent":1,"parameters":[2]},{"code":222,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":[""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["海雅人：我…只要我还是店员，"]},{"code":401,"indent":1,"parameters":["工作的事情我就不会推辞的。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["我决定用一句听起来还比较豪言壮语的话"]},{"