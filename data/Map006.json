":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：不过现在你是员工不是客人了，"]},{"code":401,"indent":1,"parameters":["我可不会像之前那么遂你的愿了。"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：还是说其实你现在还不需要帮忙？"]},{"code":231,"indent":1,"parameters":[1,"CG013",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[1,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[2]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\dac海猫抬起了头，红色的眼眸闯入视野和我对视着。"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\dac我的身体告诉我，自己没有说不的理由。"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：今天只用手哦？"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\dac我僵硬地点了点头。"]},{"code":231,"indent":1,"parameters":[2,"CG014",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[2,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：我可不是在征求你的意见哦？"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\dac像被捏住后颈的鸭子一样，我的脑袋僵在原地。"]},{"code":101,"indent":1,"parameters":["",0,1,2]},{"code":401,"indent":1,"parameters":["\\dac被压抑住的噗嗤笑声传来，"]},{"code":401,"indent":1,"parameters":["\\dac很难想象我现在脸上是什么精彩的模样。"]},{"code":231,"indent":1,"parameters":[1,"CG015",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[1,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[2]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac拉链声传来，下身突然有种莫名的松弛感。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac下头轻松上头紧张，我考考你，这该怎么形容。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac这个世界颜色那么少，那精液会是什么颜色？"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac如果一个人嘴上说不爱你，行为却好像爱你，"]},{"code":401,"indent":1,"parameters":["\\dac那你应该看了几年动画片？"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac纷乱的思绪占领了我的大脑，但下身却继续充血。"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：上次的时候，你不是挺强硬的吗？"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["（那时候的我可是真正的无敌之人啊…"]},{"code":401,"indent":1,"parameters":["再不强硬可就要去下辈子了…）"]},{"code":230,"indent":1,"parameters":[30]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：噗嗤。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac你刚刚笑我了吧！明明就是笑我了吧！"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac不过我现在确实应该挺可笑的？"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac不知道和第一次到酒馆时候的我谁更可笑。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac“其实我是个杀人犯！”，哈哈哈哈哈"]},{"code":231,"indent":1,"parameters":[2,"CG016",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[2,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac为了屏蔽快感不断寻找着转移注意力的目标，"]},{"code":401,"indent":1,"parameters":["\\dac我的大脑CPU可能也快烧了吧。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac但海猫已经把第二只手搭了上来。"]},{"code":401,"indent":1,"parameters":["\\dac两只手有节奏地上下撸动着。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac不要想着逃跑比较好哦，红色的眼眸仿佛在对我说着。"]},{"code":231,"indent":1,"parameters":[1,"CG017",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[1,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[2]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac虽然话语停下了，但动作始终没有停下。"]},{"code":401,"indent":1,"parameters":["\\dac和言语的嘲笑不同，她的手一直保持着温柔和节奏感。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac说不定其实她现在正当自己在打音游？"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac阿海唱歌不算很好，不知道音游技术怎么样？"]},{"code":231,"indent":1,"parameters":[2,"CG016",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[2,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac话又说回来，这个海猫不是阿海啊，好像没法这么比？"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac大脑努力地做着拉扯，但我不得不承认，"]},{"code":401,"indent":1,"parameters":["\\dac确实这些天欲望已经累积过多了。"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：不是玩音游，只是单纯的服务而已。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac这里应该有个问题。"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac应该是有个吐槽…"]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac或者是顺着话问点…"]},{"code":230,"indent":1,"parameters":[30]},{"code":224,"indent":1,"parameters":[[255,255,255,170],30,true]},{"code":224,"indent":1,"parameters":[[255,255,255,170],30,true]},{"code":224,"indent":1,"parameters":[[255,255,255,170],60,false]},{"code":231,"indent":1,"parameters":[1,"CG018",0,0,0,0,100,100,0,0]},{"code":232,"indent":1,"parameters":[1,0,0,0,0,0,100,100,255,0,30,true]},{"code":235,"indent":1,"parameters":[2]},{"code":224,"indent":1,"parameters":[[255,255,255,170],30,true]},{"code":230,"indent":1,"parameters":[30]},{"code":101,"indent":1,"parameters":["",4,1,2]},{"code":401,"indent":1,"parameters":["\\dac空白空白空白空白空白空白"]},{"code":101,"indent":1,"parameters":["",4,0,2]},{"code":401,"indent":1,"parameters":["海猫：比