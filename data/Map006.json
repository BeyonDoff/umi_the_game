parameters":["诶？海猫小姐找我有事吗？"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",6,0,2]},{"code":401,"indent":0,"parameters":["嗯…倒也不算重要的事？"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["但确实需要你帮忙参考一下~"]},{"code":225,"indent":0,"parameters":[5,5,30,false]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST LEFT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",1,0,2]},{"code":401,"indent":0,"parameters":["诶？诶！！"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["\\dac我在半推半就中被海猫拉到了沙发上。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":101,"indent":0,"parameters":["umi_lihui_test",4,0,2]},{"code":401,"indent":0,"parameters":["那么，准备好了吗？"]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[1,"CG024",0,0,0,0,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac回过神来，海猫也已经坐在了我的身边。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac红色的眼睛正一眨不眨地和我对视着，"]},{"code":401,"indent":0,"parameters":["\\dac让我心跳有些不自觉地加速。"]},{"code":230,"indent":0,"parameters":[10]},{"code":356,"indent":0,"parameters":["BUST RIGHT FALSE"]},{"code":230,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：看完了吗？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac看完了吗是什么意思？"]},{"code":401,"indent":0,"parameters":["\\dac沉浸在对视之中、我大脑还处于即将液化的状态。"]},{"code":230,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：我说，看~完~了~吗~？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我浑身一激灵，连忙挺直了腰杆开始装正人君子。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac不对，我本来就是正人君子，"]},{"code":401,"indent":0,"parameters":["\\dac刚刚的对视也只是在看海猫小姐昨天睡得好不好。"]},{"code":230,"indent":0,"parameters":[30]},{"code":225,"indent":0,"parameters":[5,5,30,false]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：噗哈哈哈"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我带着僵硬的微笑转向海猫、报以绅士般的眼神询问。"]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：不是不是，我是让你先记住我的脸，"]},{"code":401,"indent":0,"parameters":["好之后做下对比啦。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac你的脸我还能记不住？我继续进行礼貌的眼神交流。"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac海猫似乎又要笑场了，但这次努力地没有发出笑声。"]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：看完了的话海雅人就先闭眼稍等一下吧。"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac我从善如流，毕竟刚才沉迷对视过久，"]},{"code":401,"indent":0,"parameters":["\\dac眼睛确实有点累了。"]},{"code":231,"indent":0,"parameters":[2,"CG022",0,0,0,0,100,100,255,0]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",4,0,2]},{"code":401,"indent":0,"parameters":["海猫：好啦好啦！"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac这么短的时间应该不是换了衣服，"]},{"code":401,"indent":0,"parameters":["\\dac不对，我的大脑在想什么？"]},{"code":101,"indent":0,"parameters":["",0,1,2]},{"code":401,"indent":0,"parameters":["\\dac祈祷着海猫没有察觉到我刚刚的想法，"]},{"code":401,"indent":0,"